import { ListView, LineEdit } from "std-widgets.slint";
import { Style, GhostButton, Badge, ConfirmDialog } from "style.slint";

export struct FileEntry {
    id: string,
    name: string,
    size: string,
    uploaded-at: string,
    content-type: string,
    sha256: string,
    expires-at: string,
    file-icon: string,
    icon-color: color,
    icon-bg: color,
}

// ── Desktop card: horizontal layout ──
component WideFileCard inherits Rectangle {
    in property <string> file-id;
    in property <string> file-name;
    in property <string> file-size;
    in property <string> file-date;
    in property <string> content-type;
    in property <string> expires-at;
    in property <string> file-icon;
    in property <color> icon-color: Style.primary;
    in property <color> icon-bg: Style.primary-light;
    callback download();
    callback delete-file();
    callback share();
    callback select();

    background: touch.has-hover ? Style.surface-hover : Style.surface;
    border-radius: Style.radius-md;
    border-width: 1px;
    border-color: touch.has-hover ? Style.border : Style.divider;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.select(); }
    }

    HorizontalLayout {
        padding-left: Style.sp-lg;
        padding-right: Style.sp-md;
        padding-top: Style.sp-md;
        padding-bottom: Style.sp-md;
        spacing: Style.sp-lg;

        Rectangle {
            width: 40px;
            height: 40px;
            border-radius: Style.radius-sm;
            background: root.icon-bg;

            Text {
                text: root.file-icon;
                font-size: 10px;
                font-weight: 700;
                color: root.icon-color;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: Style.sp-xs;
            alignment: center;

            Text {
                text: root.file-name;
                font-size: 14px;
                font-weight: 500;
                color: Style.text-primary;
                overflow: elide;
            }

            HorizontalLayout {
                spacing: Style.sp-sm;

                Badge {
                    label: root.file-size;
                    fg: Style.primary;
                    bg: Style.primary-light;
                }

                if root.expires-at != "": Badge {
                    label: "Expires " + root.expires-at;
                    fg: Style.warning;
                    bg: Style.warning-light;
                }

                Text {
                    text: root.file-date;
                    font-size: 11px;
                    color: Style.text-hint;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalLayout {
            spacing: Style.sp-xs;
            alignment: center;

            GhostButton {
                label: "Download";
                accent: Style.primary;
                clicked => { root.download(); }
            }

            GhostButton {
                label: "Share";
                accent: Style.success;
                clicked => { root.share(); }
            }

            GhostButton {
                label: "Delete";
                accent: Style.danger;
                clicked => { root.delete-file(); }
            }
        }
    }
}

// ── Mobile card: stacked vertical layout ──
component CompactFileCard inherits Rectangle {
    in property <string> file-id;
    in property <string> file-name;
    in property <string> file-size;
    in property <string> file-date;
    in property <string> content-type;
    in property <string> expires-at;
    callback download();
    callback delete-file();
    callback share();
    callback select();

    background: touch.has-hover ? Style.surface-hover : Style.surface;
    border-radius: Style.radius-md;
    border-width: 1px;
    border-color: Style.divider;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.select(); }
    }

    VerticalLayout {
        padding: Style.sp-sm;
        spacing: Style.sp-sm;

        // Row 1: name + metadata
        VerticalLayout {
            spacing: 2px;

            Text {
                text: root.file-name;
                font-size: 14px;
                font-weight: 500;
                color: Style.text-primary;
                overflow: elide;
            }

            HorizontalLayout {
                spacing: Style.sp-sm;

                Badge {
                    label: root.file-size;
                    fg: Style.primary;
                    bg: Style.primary-light;
                }

                if root.expires-at != "": Badge {
                    label: "Expires " + root.expires-at;
                    fg: Style.warning;
                    bg: Style.warning-light;
                }

                Text {
                    text: root.file-date;
                    font-size: 11px;
                    color: Style.text-hint;
                    vertical-alignment: center;
                }
            }
        }

        // Row 2: action buttons spread full width
        HorizontalLayout {
            spacing: Style.sp-xs;

            GhostButton {
                label: "Download";
                accent: Style.primary;
                horizontal-stretch: 1;
                clicked => { root.download(); }
            }

            GhostButton {
                label: "Share";
                accent: Style.success;
                horizontal-stretch: 1;
                clicked => { root.share(); }
            }

            GhostButton {
                label: "Delete";
                accent: Style.danger;
                horizontal-stretch: 1;
                clicked => { root.delete-file(); }
            }
        }
    }
}

// ── Detail row: label + value ──
component DetailRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;

    spacing: Style.sp-sm;
    padding-top: 1px;
    padding-bottom: 1px;

    Text {
        text: root.label;
        font-size: 11px;
        font-weight: 600;
        color: Style.text-hint;
        width: 70px;
    }

    Text {
        text: root.value;
        font-size: 11px;
        color: Style.text-primary;
        overflow: elide;
        horizontal-stretch: 1;
    }
}

// ── File detail panel ──
component FileDetailPanel inherits Rectangle {
    in property <FileEntry> file;
    in property <bool> compact: false;
    callback close();
    callback download();
    callback delete-file();
    callback share();

    background: Style.surface;
    border-radius: Style.radius-md;
    border-width: 1px;
    border-color: Style.border;
    horizontal-stretch: 1;
    vertical-stretch: 1;

    VerticalLayout {
        padding: Style.sp-md;
        spacing: 2px;
        alignment: start;

        // Header: name + close
        HorizontalLayout {
            spacing: Style.sp-sm;
            padding-bottom: Style.sp-xs;

            Text {
                text: root.file.name;
                font-size: 14px;
                font-weight: 600;
                color: Style.text-primary;
                overflow: elide;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }

            Badge { label: root.file.size; fg: Style.primary; bg: Style.primary-light; }

            GhostButton {
                label: "Close";
                accent: Style.text-secondary;
                clicked => { root.close(); }
            }
        }

        Rectangle { height: 1px; background: Style.divider; }

        // Metadata rows
        DetailRow { label: "ID"; value: root.file.id; }
        DetailRow { label: "Uploaded"; value: root.file.uploaded-at; }
        if root.file.content-type != "": DetailRow { label: "Type"; value: root.file.content-type; }
        if root.file.sha256 != "": DetailRow { label: "SHA-256"; value: root.file.sha256; }
        if root.file.expires-at != "": DetailRow { label: "Expires"; value: root.file.expires-at; }

        Rectangle { height: 1px; background: Style.divider; }

        // Action buttons
        HorizontalLayout {
            spacing: Style.sp-xs;
            padding-top: Style.sp-xs;

            GhostButton { label: "Download"; accent: Style.primary; clicked => { root.download(); } }
            GhostButton { label: "Share"; accent: Style.success; clicked => { root.share(); } }
            GhostButton { label: "Delete"; accent: Style.danger; clicked => { root.delete-file(); } }
        }
    }
}

component EmptyState inherits Rectangle {
    height: 200px;

    VerticalLayout {
        alignment: center;
        spacing: Style.sp-sm;

        Text {
            text: "No files";
            font-size: 18px;
            font-weight: 600;
            color: Style.text-hint;
            horizontal-alignment: center;
        }

        Text {
            text: "Upload a file to get started";
            font-size: 13px;
            color: Style.text-hint;
            horizontal-alignment: center;
        }
    }
}

component LoadingState inherits Rectangle {
    height: 200px;

    VerticalLayout {
        alignment: center;
        spacing: Style.sp-sm;

        Text {
            text: "Loading files...";
            font-size: 16px;
            font-weight: 500;
            color: Style.text-hint;
            horizontal-alignment: center;
        }
    }
}

export component FileListView inherits Rectangle {
    in property <[FileEntry]> files: [];
    in property <bool> loading: false;
    in property <string> status-message: "";
    in property <bool> status-is-error: false;
    in property <bool> compact: false;
    in-out property <string> share-url: "";
    callback refresh();
    callback download(string);
    callback delete-file(string);
    callback share(string);
    callback copy-share-url();

    // Track selected file for detail view
    property <int> selected-index: -1;
    property <bool> showing-detail: selected-index >= 0 && selected-index < files.length;

    // Delete confirmation state
    property <string> pending-delete-id: "";
    property <string> pending-delete-name: "";

    background: Style.background;

    VerticalLayout {
        padding-left: root.compact ? Style.sp-sm : Style.sp-lg;
        padding-right: root.compact ? Style.sp-sm : Style.sp-lg;
        padding-top: Style.sp-md;
        padding-bottom: Style.sp-lg;
        spacing: Style.sp-sm;

        // Header
        HorizontalLayout {
            alignment: space-between;

            Text {
                text: root.files.length > 0
                    ? "\{root.files.length} file(s)"
                    : "";
                font-size: 13px;
                font-weight: 500;
                color: Style.text-secondary;
                vertical-alignment: center;
            }

            GhostButton {
                label: root.loading ? "Loading..." : "Refresh";
                enabled: !root.loading;
                clicked => { root.refresh(); }
            }
        }

        // Status toast
        if root.status-message != "": Rectangle {
            height: 36px;
            border-radius: Style.radius-sm;
            background: root.status-is-error ? Style.danger-light : Style.success-light;

            Text {
                text: root.status-message;
                font-size: 12px;
                color: root.status-is-error ? Style.danger : Style.success;
                wrap: word-wrap;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Share URL bar (shown prominently above file list)
        if root.share-url != "": Rectangle {
            height: 44px;
            border-radius: Style.radius-sm;
            background: Style.success-light;
            border-width: 1px;
            border-color: Style.success.with-alpha(0.3);

            HorizontalLayout {
                padding-left: Style.sp-sm;
                padding-right: Style.sp-sm;
                spacing: Style.sp-sm;
                alignment: center;

                LineEdit {
                    text: root.share-url;
                    read-only: true;
                    font-size: 12px;
                    horizontal-stretch: 1;
                }

                GhostButton {
                    label: "Copy";
                    accent: Style.success;
                    clicked => { root.copy-share-url(); }
                }

                GhostButton {
                    label: "Close";
                    accent: Style.text-hint;
                    clicked => { root.share-url = ""; }
                }
            }
        }

        if root.files.length == 0 && !root.loading: EmptyState {}
        if root.files.length == 0 && root.loading: LoadingState {}

        // ── File list OR detail panel ──
        // Always-present container so layout size is stable when switching views.
        Rectangle {
            vertical-stretch: 1;

            // Detail panel (overlays on top when visible)
            if root.showing-detail: FileDetailPanel {
                width: parent.width;
                height: parent.height;
                file: root.files[root.selected-index];
                compact: root.compact;
                close => { root.selected-index = -1; }
                download => {
                    root.download(root.files[root.selected-index].id);
                    root.selected-index = -1;
                }
                delete-file => {
                    root.pending-delete-id = root.files[root.selected-index].id;
                    root.pending-delete-name = root.files[root.selected-index].name;
                    root.selected-index = -1;
                }
                share => {
                    root.share(root.files[root.selected-index].id);
                    root.selected-index = -1;
                }
            }

            // Desktop file list (always present, hidden behind detail)
            if !root.showing-detail && !root.compact: ListView {
                width: parent.width;
                height: parent.height;

                for file[i] in root.files: Rectangle {
                    height: 76px;

                    WideFileCard {
                        file-id: file.id;
                        file-name: file.name;
                        file-size: file.size;
                        file-date: file.uploaded-at;
                        content-type: file.content-type;
                        expires-at: file.expires-at;
                        file-icon: file.file-icon;
                        icon-color: file.icon-color;
                        icon-bg: file.icon-bg;
                        select => { root.selected-index = i; }
                        download => { root.download(file.id); }
                        delete-file => { root.pending-delete-id = file.id; root.pending-delete-name = file.name; }
                        share => { root.share(file.id); }
                    }
                }
            }

            // Mobile file list
            if !root.showing-detail && root.compact: ListView {
                width: parent.width;
                height: parent.height;

                for file[i] in root.files: Rectangle {
                    height: 96px;

                    CompactFileCard {
                        file-id: file.id;
                        file-name: file.name;
                        file-size: file.size;
                        file-date: file.uploaded-at;
                        content-type: file.content-type;
                        expires-at: file.expires-at;
                        select => { root.selected-index = i; }
                        download => { root.download(file.id); }
                        delete-file => { root.pending-delete-id = file.id; root.pending-delete-name = file.name; }
                        share => { root.share(file.id); }
                    }
                }
            }
        }

    }

    // Delete confirmation overlay (on top of everything)
    if root.pending-delete-id != "": ConfirmDialog {
        width: parent.width;
        height: parent.height;
        message: "Delete \"\{root.pending-delete-name}\"?";
        confirm-label: "Delete";
        confirm => {
            root.delete-file(root.pending-delete-id);
            root.pending-delete-id = "";
            root.pending-delete-name = "";
        }
        cancel => {
            root.pending-delete-id = "";
            root.pending-delete-name = "";
        }
    }
}
